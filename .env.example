# LLM provider (default: openrouter). Options: openrouter, ofox, n1n
PRI_TOPIC_CHECK_CONCEPT_EXTRACT_MODEL_PROVIDER=openrouter

# Required for OpenRouter (default provider)
OPENROUTER_PRI_TOPIC_CHECK_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=

# Alternative providers (when PRI_TOPIC_CHECK_CONCEPT_EXTRACT_MODEL_PROVIDER is ofox or n1n)
# OFOX_PRI_TOPIC_CHECK_MODEL=
# OFOX_API_KEY=
# OFOX_BASE_URL=https://api.ofox.ai/v1
# OFOX_PROVIDER_ROUTING=cost
# N1N_PRI_TOPIC_CHECK_MODEL=
# N1N_API_KEY=
# N1N_BASE_URL=https://api.n1n.ai/v1

# Optional: improves OpenAlex API rate limits
# OPENALEX_API_KEY=

# Optional OpenRouter settings
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_PROVIDER_ORDER=
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_TITLE=

# Optional LLM cache settings
# LLM_CACHE_DISABLED=0
# LLM_CACHE_TTL_SECONDS=604800
